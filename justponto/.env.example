# ─────────────────────────────────────────────
#  Origem de dados
# ─────────────────────────────────────────────
DATA_SOURCE=mock                   # mock | supabase

# ─────────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────────
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-de-64-chars
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
#  Supabase (apenas quando DATA_SOURCE=supabase)
# ─────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=anexos

# ─────────────────────────────────────────────
#  E-mail
# ─────────────────────────────────────────────
MAIL_PROVIDER=fake                 # fake | resend | sendgrid | smtp
MAIL_FROM=naoresponda@empresa.com

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# SMTP genérico
SMTP_HOST=smtp.empresa.com
SMTP_PORT=587
SMTP_USER=usuario@empresa.com
SMTP_PASS=senha-smtp
